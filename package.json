{
  "name": "motherbase",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "cli": "bun run packages/server/src/index.ts",
    "dev": "bun --filter @motherbase/web dev",
    "storybook": "bun --filter @motherbase/storybook dev",
    "format": "biome format --write",
    "lint": "biome check --write",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
